# Banco de dados (casando com o docker-compose.yml da raiz)
DB_USER=ptroster
DB_PASS=ptroster
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ptroster

# Alternativa: URL direta (Supabase/Neon/Render). Se definida, tem prioridade.
# DATABASE_URL_DIRECT=postgresql://user:pass@host:5432/dbname

# Segurança — obrigatório, mínimo 32 caracteres. Gere com: openssl rand -hex 32
SECRET_KEY=troque-esta-chave-por-uma-de-32-ou-mais-caracteres
